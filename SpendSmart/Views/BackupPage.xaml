<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:SpendSmart.ViewModels"
             x:Class="SpendSmart.Views.BackupPage"
             Title="สำรองและกู้คืนข้อมูล">

    <ContentPage.Background>
        <LinearGradientBrush EndPoint="0,1">
            <GradientStop Color="#FDFBFB" Offset="0.1" />
            <GradientStop Color="#EBEDEE" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <VerticalStackLayout Padding="30"
                         Spacing="25"
                         VerticalOptions="Center"
                         BackgroundColor="Transparent">

        <Label Text="💰"
               FontSize="140"
               HorizontalOptions="Center"
               Margin="0,0,0,10" />

        <Label Text="จัดการฐานข้อมูล"
               FontSize="24"
               FontAttributes="Bold"
               HorizontalOptions="Center" />

        <Label Text="{Binding StatusMessage}"
               HorizontalOptions="Center"
               TextColor="Gray" />

        <ActivityIndicator IsRunning="{Binding IsBusy}"
                           HorizontalOptions="Center" />

        <Button Text="☁️ สำรองข้อมูล (Backup)"
                Command="{Binding BackupDataCommand}"
                HeightRequest="60"
                CornerRadius="30"
                BackgroundColor="#D4AF37"
                TextColor="White"
                FontAttributes="Bold" />

        <Button Text="🔄 กู้คืนข้อมูล (Restore)"
                Command="{Binding RestoreDataCommand}"
                HeightRequest="60"
                CornerRadius="30"
                BackgroundColor="#2C3E50"
                TextColor="White"
                FontAttributes="Bold" />

    </VerticalStackLayout>
</ContentPage>