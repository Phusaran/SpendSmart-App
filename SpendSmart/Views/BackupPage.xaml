<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:SpendSmart.ViewModels"
             x:Class="SpendSmart.Views.BackupPage"
             Title="Backup &amp; Restore">

    <VerticalStackLayout Padding="30" Spacing="25" VerticalOptions="Center">

        <Image Source="dotnet_bot.png" HeightRequest="150" HorizontalOptions="Center" />

        <Label Text="จัดการฐานข้อมูล" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center" />
        <Label Text="{Binding StatusMessage}" HorizontalOptions="Center" TextColor="Gray" />

        <ActivityIndicator IsRunning="{Binding IsBusy}" HorizontalOptions="Center" />

        <Button Text="☁️ สำรองข้อมูล (Backup)" 
                Command="{Binding BackupDataCommand}"
                HeightRequest="60" CornerRadius="30" BackgroundColor="#3498DB" />

        <Button Text="🔄 กู้คืนข้อมูล (Restore)" 
                Command="{Binding RestoreDataCommand}"
                HeightRequest="60" CornerRadius="30" BackgroundColor="#E67E22" />

    </VerticalStackLayout>
</ContentPage>