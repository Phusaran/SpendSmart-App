<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SpendSmart.Views.ChatPage"
             Title="คุยกับ SpendSmart AI"
             BackgroundColor="#F0F4F8">

    <Grid RowDefinitions="*, Auto">

        <CollectionView Grid.Row="0" ItemsSource="{Binding Messages}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <VerticalStackLayout HorizontalOptions="{Binding Alignment}" Margin="0,5,0,5" MaximumWidthRequest="300">
                        <Label Text="{Binding SenderName}" FontSize="10" TextColor="#95A5A6" Margin="5,0"/>
                        <Frame BackgroundColor="{Binding BackgroundColor}" CornerRadius="15" Padding="15,10" HasShadow="False" BorderColor="Transparent">
                            <Label Text="{Binding Text}" TextColor="{Binding TextColor}" FontSize="14" LineBreakMode="WordWrap"/>
                        </Frame>
                    </VerticalStackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Label Grid.Row="0" Text="AI กำลังคิด..." TextColor="#95A5A6" FontSize="12" FontAttributes="Italic"
               HorizontalOptions="Start" VerticalOptions="End" Margin="20,5" IsVisible="{Binding IsTyping}"/>

        <Frame Grid.Row="1" BackgroundColor="White" Padding="10" Margin="0" CornerRadius="0" HasShadow="True">
            <Grid ColumnDefinitions="*, Auto" ColumnSpacing="10">
                <Entry Grid.Column="0" Text="{Binding InputText}" Placeholder="พิมพ์ถาม AI ที่นี่..." 
                       BackgroundColor="#F8F9FA" TextColor="#2C3E50" ReturnCommand="{Binding SendMessageCommand}"/>

                <Button Grid.Column="1" Text="ส่ง" Command="{Binding SendMessageCommand}" 
                        BackgroundColor="#D4AF37" TextColor="White" CornerRadius="20" FontAttributes="Bold" WidthRequest="60"/>
            </Grid>
        </Frame>

        <Grid Grid.Row="0" Grid.RowSpan="2"
              BackgroundColor="#90000000"
              IsVisible="{Binding IsAiPopupVisible}"
              HorizontalOptions="Fill"
              VerticalOptions="Fill">

            <Frame BackgroundColor="White"
                   CornerRadius="20"
                   WidthRequest="320"
                   VerticalOptions="Center"
                   HorizontalOptions="Center"
                   HasShadow="True"
                   Padding="20"
                   Margin="20">

                <VerticalStackLayout Spacing="15">
                    <Label Text="🤖 ตรวจสอบรายการจาก AI"
                           FontAttributes="Bold"
                           FontSize="18"
                           HorizontalOptions="Center"
                           TextColor="#2C3E50"/>

                    <BoxView HeightRequest="1" BackgroundColor="#BDC3C7" HorizontalOptions="Fill"/>

                    <Grid ColumnDefinitions="*, *">
                        <Frame Grid.Column="0" BackgroundColor="#2ECC71" Padding="5" Margin="2" CornerRadius="5">
                            <Label Text="รายรับ" TextColor="White" FontAttributes="Bold" HorizontalOptions="Center"/>
                        </Frame>
                        <Frame Grid.Column="1" BackgroundColor="#E74C3C" Padding="5" Margin="2" CornerRadius="5">
                            <Label Text="รายจ่าย" TextColor="White" FontAttributes="Bold" HorizontalOptions="Center"/>
                        </Frame>
                    </Grid>

                    <VerticalStackLayout Spacing="2">
                        <Label Text="จำนวนเงิน (บาท)" FontSize="12" TextColor="#7F8C8D"/>
                        <Entry Text="{Binding AiAmount}" Keyboard="Numeric" FontSize="16" FontAttributes="Bold" TextColor="#2C3E50"/>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="2">
                        <Label Text="หมวดหมู่" FontSize="12" TextColor="#7F8C8D"/>
                        <Entry Text="{Binding AiSubCategory}" FontSize="14" TextColor="#2C3E50"/>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="2">
                        <Label Text="บันทึกช่วยจำ" FontSize="12" TextColor="#7F8C8D"/>
                        <Entry Text="{Binding AiNote}" FontSize="14" TextColor="#2C3E50"/>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="2">
                        <Label Text="หัก/เข้า จากกระเป๋าไหน?" FontSize="12" TextColor="#7F8C8D" FontAttributes="Bold"/>
                        <Picker ItemsSource="{Binding Pockets}"
                                ItemDisplayBinding="{Binding Name}"
                                SelectedItem="{Binding SelectedPocket}" />
                    </VerticalStackLayout>

                    <Grid ColumnDefinitions="*, *" ColumnSpacing="10" Margin="0,10,0,0">
                        <Button Grid.Column="0" Text="ยกเลิก" 
                                BackgroundColor="#BDC3C7" TextColor="White" FontAttributes="Bold"
                                Command="{Binding ClosePopupCommand}"/>
                        <Button Grid.Column="1" Text="บันทึกเลย" 
                                BackgroundColor="#2ECC71" TextColor="White" FontAttributes="Bold"
                                Command="{Binding ConfirmTransactionCommand}"/>
                    </Grid>
                </VerticalStackLayout>
            </Frame>
        </Grid>

    </Grid>
</ContentPage>